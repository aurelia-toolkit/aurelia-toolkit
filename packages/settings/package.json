{
  "name": "@aurelia-toolkit/settings",
  "version": "4.0.3",
  "publishConfig": {
    "access": "public"
  },
  "description": "Aurelia Toolkit Settings",
  "keywords": [
    "aurelia",
    "toolkit",
    "settings"
  ],
  "homepage": "http://aurelia.io",
  "bugs": {
    "url": "https://github.com/aurelia-toolkit/aurelia-toolkit/issues"
  },
  "license": "MIT",
  "author": "Maxim Balaganskiy <m.balaganskiy@gmail.com>",
  "contributors": [],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "typings": "dist/types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/aurelia-toolkit/aurelia-toolkit"
  },
  "files": [
    "dist",
    "*.scss"
  ],
  "scripts": {
    "build-ts:code": "tsc -p tsconfig.build.json --outDir dist",
    "build-ts:types": "tsc -p tsconfig.build.json --skipLibCheck -d --emitDeclarationOnly --declarationDir dist/types",
    "build-assets": "copyfiles -u 1 src/**/*.html src/**/*.css src/**/*.scss dist",
    "prebuild": "rimraf dist",
    "build": "concurrently \"npm:build-ts:*\" && concurrently \"npm:build-assets\""
  },
  "peerDependencies": {
    "@aurelia-mdc-web/button": ">=9.0.8",
    "@aurelia-mdc-web/dialog": ">=9.0.8",
    "@aurelia-mdc-web/switch": ">=9.0.8",
    "@aurelia-mdc-web/text-field": ">=9.0.8",
    "aurelia-i18n": "^4.0.3",
    "aurelia-logging": "^1.5.2"
  }
}
